# Coolify API Configuration
COOLIFY_URL=https://coolify.uinjambi.ac.id
COOLIFY_API_KEY=your-api-key-here

# Refresh interval in seconds
REFRESH_INTERVAL=5

# Web Dashboard port
WEB_PORT=5555

# Dashboard Security
MONITOR_PASSWORD=your-password-here
FLASK_SECRET_KEY=your-random-secret-key-here

# Monitor Agent Configuration
MONITOR_AGENT_URL=https://agent.uinjambi.ac.id
MONITOR_AGENT_TOKEN=your-agent-token-here
